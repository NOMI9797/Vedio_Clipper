DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?sslmode=require
AUTH_JWT_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Cloudflare R2 (S3 API) — used for file uploads in production
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Local dev: set to 1 to store uploads on disk when R2 is not set (npm run dev only)
# OBJECT_STORE_LOCAL=1
# Optional custom folder (default: .local-object-store at project root)
# OBJECT_STORE_LOCAL_DIR=.local-object-store

# US-05 transcription worker (Deepgram or OpenAI Whisper)
# DEEPGRAM_API_KEY=
# OPENAI_API_KEY=
# TRANSCRIPTION_PROVIDER=deepgram
# FFMPEG_PATH=ffmpeg
# YTDLP_PATH=yt-dlp
# WORKER_SECRET= # required for POST /api/worker/transcribe (header x-worker-secret)
